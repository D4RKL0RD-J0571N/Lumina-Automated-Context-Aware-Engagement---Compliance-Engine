{
  "version": 2,
  "name": "lumina-engine",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "/api/v1",
    "VITE_AI_MODEL_URL": "https://lashanda-nontelegraphical-ozella.ngrok-free.dev",
    "VITE_APP_NAME": "Lumina Engine",
    "VITE_APP_VERSION": "1.0.0",
    "LM_STUDIO_URL": "https://lashanda-nontelegraphical-ozella.ngrok-free.dev",
    "LM_STUDIO_API_KEY": "your-api-key-here"
  }
}