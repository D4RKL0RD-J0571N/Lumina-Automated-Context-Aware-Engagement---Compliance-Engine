{
  "version": 2,
  "name": "lumina-engine",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/domains/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/orchestrate/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/compliance/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "VITE_API_URL": "/api/v1",
    "VITE_AI_MODEL_URL": "https://lashanda-nontelegraphical-ozella.ngrok-free.dev",
    "VITE_APP_NAME": "Lumina Engine",
    "VITE_APP_VERSION": "1.0.0",
    "LM_STUDIO_URL": "https://lashanda-nontelegraphical-ozella.ngrok-free.dev",
    "LM_STUDIO_API_KEY": "your-api-key-here"
  }
}